# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
CORS_ORIGIN=http://localhost:5173

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=visionex_tv
DB_USER=postgres
DB_PASSWORD=changeme
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=20

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=change-this-to-a-random-64-char-secret-in-production
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ── Streaming ─────────────────────────────────────────────────────────────────
STREAM_TOKEN_TTL_HOURS=4
STREAM_HEALTH_INTERVAL_MS=30000
STREAM_MAX_RETRIES=3
STREAM_FAILOVER_TIMEOUT_MS=2000
STREAM_PROXY_URL=

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

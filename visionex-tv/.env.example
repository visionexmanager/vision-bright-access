# ╔══════════════════════════════════════════════════════════╗
# ║         VISIONEX TV — Backend Environment Config         ║
# ╚══════════════════════════════════════════════════════════╝
# Copy to .env and fill in values before running.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
# Comma-separated origins for CORS + Socket.io
CORS_ORIGIN=http://localhost:5173

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=visionex_tv
DB_USER=postgres
DB_PASSWORD=changeme_strong_password
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=20

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_64_CHAR_HEX_SECRET_IN_PRODUCTION
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ── Streaming Engine ──────────────────────────────────────────────────────────
STREAM_TOKEN_TTL_HOURS=4
STREAM_HEALTH_INTERVAL_MS=30000   # how often the orchestrator probes sources
STREAM_MAX_RETRIES=3
STREAM_FAILOVER_TIMEOUT_MS=2000   # max time before declaring a failover
STREAM_PROXY_URL=                 # optional: URL of your HLS proxy

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_TTL=60       # seconds
RATE_LIMIT_MAX=100      # requests per window
